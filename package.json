{
	"name": "wikiplus-highlight",
	"version": "3.4.1",
	"description": "A plugin for the MediaWiki front-end add-on \"Wikiplus\"",
	"keywords": [
		"mediawiki",
		"codemirror",
		"monaco"
	],
	"homepage": "https://github.com/bhsd-harry/Wikiplus-highlight#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/Wikiplus-highlight/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"/dist/main.min.js"
	],
	"browser": "/dist/main.min.js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/Wikiplus-highlight.git"
	},
	"scripts": {
		"ls": "npm i --package-lock-only && npm ls --package-lock-only --all --omit=dev",
		"prepublishOnly": "npm run build",
		"lint:ts": "tsc && eslint --cache .",
		"lint:css": "stylelint *.css",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:css && npm run lint:md",
		"bundle": "node bundle.cjs",
		"build": "npm run bundle && eslint --no-config-lookup -c eslint.dist.mjs dist/*.js"
	},
	"devDependencies": {
		"@bhsd/browser": "^0.3.0",
		"@bhsd/code-standard": "^2.4.1",
		"@bhsd/codemirror-mediawiki": "^3.15.0",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@stylistic/stylelint-plugin": "^5.1.0",
		"@types/jquery": "^3.5.34",
		"@types/node": "^24.11.0",
		"@types/oojs-ui": "^0.49.4",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"esbuild": "^0.28.0",
		"eslint": "^10.3.0",
		"eslint-plugin-es-x": "^9.6.0",
		"eslint-plugin-jsdoc": "^62.9.0",
		"eslint-plugin-jsonc": "^3.1.2",
		"eslint-plugin-promise": "^7.3.0",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-unicorn": "^64.0.0",
		"eslint-plugin-yml": "^3.3.2",
		"markdownlint-cli2": "^0.22.1",
		"monaco-editor": "~0.53.0",
		"stylelint": "^17.10.0",
		"stylelint-config-recommended": "^18.0.0",
		"stylelint-plugin-use-baseline": "^1.4.1",
		"types-mediawiki": "^2.0.0",
		"typescript": "^6.0.3"
	}
}
