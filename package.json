{
	"name": "wikiplus-highlight",
	"version": "3.4.0",
	"description": "A plugin for the MediaWiki front-end add-on \"Wikiplus\"",
	"keywords": [
		"mediawiki",
		"codemirror",
		"monaco"
	],
	"homepage": "https://github.com/bhsd-harry/Wikiplus-highlight#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/Wikiplus-highlight/issues"
	},
	"license": "GPL-3.0",
	"author": "Bhsd",
	"files": [
		"/dist/main.min.js"
	],
	"browser": "/dist/main.min.js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/Wikiplus-highlight.git"
	},
	"scripts": {
		"prepublishOnly": "npm run build",
		"lint:ts": "tsc --noEmit && eslint --cache .",
		"lint:css": "stylelint *.css",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:css && npm run lint:md",
		"bundle": "node bundle.cjs",
		"build": "npm run bundle && eslint --no-config-lookup -c eslint.dist.mjs dist/*.js"
	},
	"devDependencies": {
		"@bhsd/browser": "^0.3.0",
		"@bhsd/code-standard": "^2.1.0",
		"@bhsd/codemirror-mediawiki": "^3.11.2",
		"@stylistic/eslint-plugin": "^5.9.0",
		"@stylistic/stylelint-plugin": "^5.0.1",
		"@types/jquery": "^3.5.34",
		"@types/node": "^24.11.0",
		"@types/oojs-ui": "^0.49.4",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.3",
		"eslint-plugin-es-x": "^9.5.0",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-jsdoc": "^62.7.1",
		"eslint-plugin-jsonc": "^3.1.1",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-regexp": "^3.0.0",
		"eslint-plugin-unicorn": "^63.0.0",
		"markdownlint-cli2": "^0.21.0",
		"monaco-editor": "^0.55.1",
		"stylelint": "^17.4.0",
		"stylelint-config-recommended": "^18.0.0",
		"stylelint-plugin-use-baseline": "^1.2.4",
		"types-mediawiki": "^2.0.0",
		"typescript": "^5.9.3"
	}
}
